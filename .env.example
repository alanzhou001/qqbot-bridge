# Copy to .env and fill the secrets before running.
NAPCAT_WS_URL=ws://127.0.0.1:3001
NAPCAT_ACCESS_TOKEN=change-me

OPENCLAW_AGENT=qqbot
OPENCLAW_CHANNEL=qqbot
OPENCLAW_CLI=/opt/homebrew/bin/openclaw
# Required if OpenClaw gateway.auth.token/password is stored as a secret reference.
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=

BOT_QQ=123456789
GROUP_REQUIRE_MENTION=true
ALLOWED_GROUPS=
BLOCKED_USERS=
ADMINS=

DATA_DIR=/Volumes/File/qqbot-data
DB_PATH=/Volumes/File/qqbot-data/qqbot.sqlite3
KNOWLEDGE_DIR=/Volumes/File/qqbot-data/knowledge
RAG_CONTEXT_DIR=/Volumes/File/qqbot-data/rag_context
RAG_CONTEXT_MAX_CHARS=12000
KNOWLEDGE_TOPN=6
OLLAMA_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=qwen3-embedding:0.6b
SOFFICE=/Users/alanz/.cache/codex-runtimes/codex-primary-runtime/dependencies/bin/soffice
PDFTOPPM=/Users/alanz/.cache/codex-runtimes/codex-primary-runtime/dependencies/bin/pdftoppm
TESSERACT=/opt/homebrew/bin/tesseract
TESSERACT_LANG=chi_sim+eng

MAX_INPUT_CHARS=1500
MAX_REPLY_CHARS_PER_MSG=900
OPENCLAW_TIMEOUT=120
USER_COOLDOWN_SECONDS=8
GROUP_COOLDOWN_SECONDS=2
LOG_LEVEL=INFO
